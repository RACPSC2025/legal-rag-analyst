# ===========================================
# Configuración del Sistema RAG Legal (AWS BEDROCK) - EJEMPLO
# ===========================================

# ── 1. Credenciales AWS ─────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=TU_ACCESS_KEY_AQUI
AWS_SECRET_ACCESS_KEY=TU_SECRET_KEY_AQUI
AWS_REGION=us-east-2
# IMPORTANTE: Si es una llave AKIA (IAM User), NO agregar AWS_SESSION_TOKEN
AWS_SESSION_TOKEN=""

# ── 2. Modelos de AWS Bedrock (Inference Profiles) ──────────────────────
# Modelo principal para consultas RAG normales (rápido, económico)
AWS_MODEL_SIMPLE_TEXT="us.amazon.nova-lite-v1:0"

# Modelo para análisis profundo (mayor capacidad de razonamiento)
AWS_MODEL_DEEP_ANALYSIS="us.meta.llama3-3-70b-instruct-v1:0"

# Modelo para análisis de imágenes (multimodal)
AWS_IMAGE_ANALYSIS="us.amazon.nova-pro-v1:0"

# Modelo para PDF directo (gran contexto 256k tokens)
AWS_MODEL_LARGE_CONTEXT="us.amazon.nova-2-lite-v1:0"

# ── 3. Parámetros del LLM ───────────────────────────────────────────────
LLM_TEMPERATURE="0.0"
LLM_MAX_TOKENS="2048"

# ── 4. Límites y Velocidad ───────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE="10"
RATE_LIMIT_BURST_LIMIT="3"
MAX_RETRIES="3"
INGESTION_BATCH_SIZE="5"

# ── 5. Parámetros RAG ───────────────────────────────────────────────────
CHUNK_SIZE=2500
CHUNK_OVERLAP=400
TOP_K_DOCS=10
SIMILARITY_THRESHOLD=0.75

# ── 6. Base de Datos Vectorial (ChromaDB) ───────────────────────────────
VECTOR_DB="chromadb"
VECTOR_DB_COLLECTION_NAME="my_collection"
VECTOR_DB_DIMENSION="1024"  # Requerido por Amazon Titan Embeddings v2

# ── 7. Rutas del Sistema ────────────────────────────────────────────────
DATA_INPUT_PATH="./data/input"
DATA_PROCESSED_PATH="./data/processed/"
DATA_STORAGE_PATH="./storage/"
LOGS_PATH="./logs/"

# ── 8. LlamaParse (Opcional) ───────────────────────────────────────────
LLAMA_PARSE_API_KEY="tu_api_key_de_llamaparse_aqui"
